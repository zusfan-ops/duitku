<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve static files from public/ directly (css, js, images, etc)
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.+)$ public/$1 [L]

    # Serve static directories from public/ directly
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^(.+)$ public/$1 [L]

    # Forward all other requests to public/index.php (CI4 front controller)
    RewriteRule ^ public/index.php [L]
</IfModule>
